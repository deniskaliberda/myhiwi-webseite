# MyHiwi — Environment Variables
# Copy to .env.local for local dev. In production set these in the Vercel
# dashboard (Project Settings -> Environment Variables, Production + Preview).
#
# !! BOM/CRLF-Falle (Lehre Vitalis 2026-05-29): Tokens NICHT per PowerShell
#    `vercel env add NAME prod` mit Pipe setzen -- das schleust BOM/CRLF ein und
#    zerschiesst den Token. Im Vercel-Dashboard einfuegen ODER ASCII-Datei +
#    `cmd /c "vercel env add NAME prod < file"`. Danach Redeploy.

# --- E-Mail (Resend, EU-Region) -------------------------------------------
RESEND_API_KEY=
# Empfaenger der Formular-Anfragen (optional, Default: kontakt@myhiwi.de)
CONTACT_EMAIL=kontakt@myhiwi.de

# --- Meta Pixel + Conversions API (FeWo-Tracking) -------------------------
# Pixel-ID aus dem Meta Events Manager. Browser-Pixel (public) und Server-CAPI
# nutzen denselben Wert.
NEXT_PUBLIC_META_PIXEL_ID=
META_PIXEL_ID=
# System-User Access Token (laeuft nicht ab). SECRET -- nie als NEXT_PUBLIC.
META_CAPI_ACCESS_TOKEN=
# Nur waehrend der Verifikation im Meta Test-Events-Tool setzen. Danach aus
# Vercel ENTFERNEN + Redeploy, sonst zaehlen echte Events als Test.
META_CAPI_TEST_CODE=

# --- Google Analytics 4 + Google Ads --------------------------------------
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Conversion-Label der Primaer-Conversion "Direktbuchungs-Check angefragt"
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
